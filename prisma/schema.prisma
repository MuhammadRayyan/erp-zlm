// AccountERP — Complete Prisma Schema (Multi-Tenant SaaS Edition)
// UAE-compliant double-entry accounting ERP
// Database: SQLite (dev) / PostgreSQL (prod)
// To switch to PostgreSQL: change provider to "postgresql" and update DATABASE_URL
// Tenant isolation: row-level via tenantId on all business-scoped tables

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Default: SQLite for local development
  // For production: change to provider = "postgresql"
  // Then run: bun run db:push
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// PLATFORM LEVEL (shared, no tenant scoping)
// ============================================================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  passwordHash  String?
  role          String   @default("USER") // PLATFORM_ADMIN, USER
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenantMemberships UserTenant[]
  journalEntries    JournalEntry[]  @relation("JournalEntryCreatedBy")
  invoices          SalesInvoice[]  @relation("InvoiceCreatedBy")
  bills             PurchaseBill[]  @relation("BillCreatedBy")
  payments          Payment[]       @relation("PaymentCreatedBy")
  auditLogs         AuditLog[]
  activities        ActivityLog[]
}

// A Tenant = a customer organization that bought a license/subscription
model Tenant {
  id            String   @id @default(cuid())
  name          String   // organization name
  slug          String   @unique // URL-friendly identifier
  email         String   // billing contact
  phone         String?
  status        String   @default("ACTIVE") // ACTIVE, SUSPENDED, TRIAL, CANCELLED
  trialEndsAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscription  Subscription?
  members       UserTenant[]
  businesses    Business[]
  auditLogs     AuditLog[]
  licenses      License[]
}

// A user's membership in a tenant, with a role
model UserTenant {
  id         String   @id @default(cuid())
  userId     String
  tenantId   String
  role       String   @default("ACCOUNTANT") // TENANT_ADMIN, ACCOUNTANT, VIEWER
  isActive   Boolean  @default(true)
  invitedAt  DateTime @default(now())
  joinedAt   DateTime?

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
}

// Subscription plans define limits and features
model Plan {
  id              String   @id @default(cuid())
  name            String   @unique // Free, Starter, Professional, Enterprise
  description     String?
  maxBusinesses   Int      @default(1)
  maxUsers        Int      @default(2)
  maxInvoicesPerMonth Int  @default(100) // 0 = unlimited
  priceMonthly    Decimal  @default(0)
  priceYearly     Decimal  @default(0)
  features        String   @default("{}") // JSON: { eInvoicing: true, api: false, ... }
  isActive        Boolean  @default(true)
  isPublic        Boolean  @default(true)
  createdAt       DateTime @default(now())

  subscriptions   Subscription[]
}

// A tenant's subscription to a plan
model Subscription {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  planId          String
  status          String   @default("TRIAL") // TRIAL, ACTIVE, PAST_DUE, CANCELLED, PAUSED
  billingCycle    String   @default("MONTHLY") // MONTHLY, YEARLY
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  trialEndsAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan            Plan     @relation(fields: [planId], references: [id])

  @@index([planId])
}

// Licenses for self-hosted / offline deployments
model License {
  id            String   @id @default(cuid())
  key           String   @unique
  tenantId      String?  // null = unassigned
  tenant        Tenant?  @relation(fields: [tenantId], references: [id])
  planName      String
  type          String   @default("ANNUAL") // LIFETIME, ANNUAL, MONTHLY
  maxBusinesses Int      @default(1)
  maxUsers      Int      @default(2)
  issuedTo      String?  // customer email
  issuedAt      DateTime @default(now())
  expiresAt     DateTime?
  status        String   @default("ACTIVE") // ACTIVE, EXPIRED, REVOKED, SUSPENDED
  notes         String?
  createdAt     DateTime @default(now())

  @@index([tenantId])
  @@index([status])
}

// ============================================================
// BUSINESS LEVEL (tenant-scoped via tenantId)
// ============================================================

model Business {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  legalName       String?
  trn             String?  // UAE Tax Registration Number (15 digits)
  email           String?
  phone           String?
  website         String?
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?  // Emirate
  postalCode      String?
  country         String   @default("AE")
  baseCurrency    String   @default("AED")
  fiscalYearStart String   @default("01-01")
  logoUrl         String?
  vatRegistered   Boolean  @default(true)
  vatRate         Decimal  @default(5.00)
  invoicePrefix   String   @default("INV-")
  billPrefix      String   @default("BILL-")
  quotationPrefix String   @default("QT-")
  creditNotePrefix String  @default("CN-")
  receiptPrefix   String   @default("RCT-")
  paymentPrefix   String   @default("PMT-")
  deliveryNotePrefix String @default("DN-")
  nextInvoiceNumber     Int @default(1)
  nextBillNumber        Int @default(1)
  nextQuotationNumber   Int @default(1)
  nextCreditNoteNumber  Int @default(1)
  nextReceiptNumber     Int @default(1)
  nextPaymentNumber     Int @default(1)
  nextDeliveryNoteNumber Int @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accounts        Account[]
  parties         Party[]
  journalEntries  JournalEntry[]
  salesInvoices   SalesInvoice[]
  purchaseBills   PurchaseBill[]
  quotations      Quotation[]
  creditNotes     CreditNote[]
  deliveryNotes   DeliveryNote[]
  payments        Payment[]
  items           Item[]
  bankAccounts    BankAccount[]
  taxRates        TaxRate[]
  currencies      Currency[]
  customFields    CustomFieldDefinition[]
  pdfTemplates    PdfTemplate[]
  auditLogs       AuditLog[]
  warehouses      Warehouse[]
  stockMovements  StockMovement[]
  activities      ActivityLog[]

  @@index([tenantId])
}

// ============================================================
// CHART OF ACCOUNTS
// ============================================================

model Account {
  id            String   @id @default(cuid())
  businessId    String
  code          String
  name          String
  nameAr        String?
  type          String   // ASSET, LIABILITY, EQUITY, INCOME, EXPENSE
  subtype       String?
  parentId      String?
  description   String?
  isControl     Boolean  @default(false)
  isSystem      Boolean  @default(false)
  isActive      Boolean  @default(true)
  openingBalance Decimal @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business      Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  parent        Account?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children      Account[] @relation("AccountHierarchy")
  journalLines  JournalLine[]

  @@unique([businessId, code])
  @@index([businessId, type])
  @@index([parentId])
}

// ============================================================
// JOURNAL ENTRIES (Double-Entry)
// ============================================================

model JournalEntry {
  id          String   @id @default(cuid())
  businessId  String
  number      String
  date        DateTime
  reference   String?
  description String?
  sourceType  String?  // SALES_INVOICE, PURCHASE_BILL, PAYMENT, MANUAL, etc.
  sourceId    String?
  isPosted    Boolean  @default(false)
  postedAt    DateTime?
  isReversed  Boolean  @default(false)
  reversedById String?
  createdById  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business    Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdBy   User         @relation("JournalEntryCreatedBy", fields: [createdById], references: [id])
  lines       JournalLine[]

  @@unique([businessId, number])
  @@index([businessId, date])
  @@index([sourceType, sourceId])
}

model JournalLine {
  id            String   @id @default(cuid())
  journalEntryId String
  accountId     String
  debit         Decimal  @default(0)
  credit        Decimal  @default(0)
  description   String?
  partyId       String?
  party         Party?   @relation(fields: [partyId], references: [id])
  createdAt     DateTime @default(now())

  journalEntry  JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account       Account      @relation(fields: [accountId], references: [id])

  @@index([accountId])
  @@index([journalEntryId])
}

// ============================================================
// PARTIES (Customers & Suppliers)
// ============================================================

model Party {
  id            String   @id @default(cuid())
  businessId    String
  code          String?
  name          String
  nameAr        String?
  type          String   @default("CUSTOMER")
  trn           String?
  email         String?
  phone         String?
  website       String?
  contactPerson String?
  billingAddress1   String?
  billingAddress2   String?
  billingCity       String?
  billingState      String?
  billingPostalCode String?
  billingCountry    String   @default("AE")
  shippingAddress1  String?
  shippingAddress2  String?
  shippingCity      String?
  shippingState     String?
  shippingPostalCode String?
  shippingCountry   String   @default("AE")
  paymentTerms  Int      @default(30)
  creditLimit   Decimal  @default(0)
  openingBalance Decimal @default(0)
  openingBalanceType String @default("DEBIT")
  notes         String?
  isActive      Boolean  @default(true)
  customFields  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoices      SalesInvoice[]
  bills         PurchaseBill[]
  payments      Payment[]
  journalLines  JournalLine[]
  quotations    Quotation[]
  creditNotes   CreditNote[]
  deliveryNotes DeliveryNote[]

  @@unique([businessId, code])
  @@index([businessId, type])
}

// ============================================================
// TAX RATES
// ============================================================

model TaxRate {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  nameAr      String?
  rate        Decimal
  category    String
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoiceLines SalesInvoiceLine[]
  billLines    PurchaseBillLine[]
  quotationLines QuotationLine[]
  creditNoteLines CreditNoteLine[]

  @@unique([businessId, name])
}

// ============================================================
// CURRENCIES
// ============================================================

model Currency {
  id          String   @id @default(cuid())
  businessId  String
  code        String
  name        String
  symbol      String
  isBase      Boolean  @default(false)
  exchangeRate Decimal @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, code])
}

// ============================================================
// SALES INVOICES
// ============================================================

model SalesInvoice {
  id            String   @id @default(cuid())
  businessId    String
  number        String
  date          DateTime
  dueDate       DateTime
  partyId       String
  reference     String?
  currency      String   @default("AED")
  exchangeRate  Decimal  @default(1)
  subtotal      Decimal  @default(0)
  totalDiscount Decimal  @default(0)
  totalTax      Decimal  @default(0)
  total         Decimal  @default(0)
  amountPaid    Decimal  @default(0)
  status        String   @default("DRAFT")
  notes         String?
  terms         String?
  customFields  String?
  einvoiceUuid  String?
  einvoiceXml   String?
  postedAt      DateTime?
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business      Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  party         Party     @relation(fields: [partyId], references: [id])
  createdBy     User      @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  lines         SalesInvoiceLine[]
  payments      PaymentAllocation[]

  @@unique([businessId, number])
  @@index([businessId, date])
  @@index([businessId, status, date])
  @@index([businessId, partyId, date])
  @@index([businessId, number])
  @@index([partyId])
  @@index([status])
}

model SalesInvoiceLine {
  id            String   @id @default(cuid())
  invoiceId     String
  itemId        String?
  description   String
  quantity      Decimal
  unitPrice     Decimal
  discount      Decimal  @default(0)
  position      Int      @default(0)
  taxRateId     String?
  taxRate       TaxRate?       @relation(fields: [taxRateId], references: [id])
  lineTotal     Decimal
  lineTax       Decimal  @default(0)

  invoice       SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ============================================================
// PURCHASE BILLS
// ============================================================

model PurchaseBill {
  id            String   @id @default(cuid())
  businessId    String
  number        String
  date          DateTime
  dueDate       DateTime
  partyId       String
  supplierInvoiceNumber String?
  reference     String?
  currency      String   @default("AED")
  exchangeRate  Decimal  @default(1)
  subtotal      Decimal  @default(0)
  totalDiscount Decimal  @default(0)
  totalTax      Decimal  @default(0)
  total         Decimal  @default(0)
  amountPaid    Decimal  @default(0)
  status        String   @default("DRAFT")
  notes         String?
  customFields  String?
  postedAt      DateTime?
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  party         Party    @relation(fields: [partyId], references: [id])
  createdBy     User     @relation("BillCreatedBy", fields: [createdById], references: [id])
  lines         PurchaseBillLine[]
  payments      PaymentAllocation[]

  @@unique([businessId, number])
  @@index([businessId, date])
  @@index([businessId, status, date])
  @@index([businessId, partyId, date])
  @@index([businessId, number])
  @@index([partyId])
  @@index([status])
}

model PurchaseBillLine {
  id            String   @id @default(cuid())
  billId        String
  itemId        String?
  description   String
  quantity      Decimal
  unitPrice     Decimal
  discount      Decimal  @default(0)
  position      Int      @default(0)
  taxRateId     String?
  taxRate       TaxRate?       @relation(fields: [taxRateId], references: [id])
  lineTotal     Decimal
  lineTax       Decimal  @default(0)

  bill          PurchaseBill @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
}

// ============================================================
// QUOTATIONS
// ============================================================

model Quotation {
  id            String   @id @default(cuid())
  businessId    String
  number        String
  date          DateTime
  validUntil    DateTime?
  partyId       String
  reference     String?
  currency      String   @default("AED")
  subtotal      Decimal  @default(0)
  totalDiscount Decimal  @default(0)
  totalTax      Decimal  @default(0)
  total         Decimal  @default(0)
  status        String   @default("DRAFT")
  notes         String?
  terms         String?
  customFields  String?
  convertedInvoiceId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  party         Party    @relation(fields: [partyId], references: [id])
  lines         QuotationLine[]

  @@unique([businessId, number])
  @@index([partyId])
}

model QuotationLine {
  id            String   @id @default(cuid())
  quotationId   String
  itemId        String?
  description   String
  quantity      Decimal
  unitPrice     Decimal
  discount      Decimal  @default(0)
  position      Int      @default(0)
  taxRateId     String?
  taxRate       TaxRate?       @relation(fields: [taxRateId], references: [id])
  lineTotal     Decimal
  lineTax       Decimal  @default(0)

  quotation     Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

// ============================================================
// CREDIT NOTES
// ============================================================

model CreditNote {
  id            String   @id @default(cuid())
  businessId    String
  number        String
  date          DateTime
  partyId       String
  originalInvoiceId String?
  reference     String?
  currency      String   @default("AED")
  subtotal      Decimal  @default(0)
  totalTax      Decimal  @default(0)
  total         Decimal  @default(0)
  status        String   @default("DRAFT")
  reason        String?
  notes         String?
  customFields  String?
  postedAt      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  party         Party    @relation(fields: [partyId], references: [id])
  lines         CreditNoteLine[]

  @@unique([businessId, number])
}

model CreditNoteLine {
  id            String   @id @default(cuid())
  creditNoteId  String
  description   String
  quantity      Decimal
  unitPrice     Decimal
  position      Int      @default(0)
  taxRateId     String?
  taxRate       TaxRate?       @relation(fields: [taxRateId], references: [id])
  lineTotal     Decimal
  lineTax       Decimal  @default(0)

  creditNote    CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
}

// ============================================================
// DELIVERY NOTES
// ============================================================

model DeliveryNote {
  id            String   @id @default(cuid())
  businessId    String
  number        String
  date          DateTime
  partyId       String
  invoiceId     String?
  reference     String?
  status        String   @default("DRAFT")
  notes         String?
  customFields  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business      Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  party         Party             @relation(fields: [partyId], references: [id])
  lines         DeliveryNoteLine[]

  @@unique([businessId, number])
}

model DeliveryNoteLine {
  id            String   @id @default(cuid())
  deliveryNoteId String
  itemId        String?
  description   String
  quantity      Decimal
  position      Int      @default(0)

  deliveryNote  DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
}

// ============================================================
// PAYMENTS
// ============================================================

model Payment {
  id            String   @id @default(cuid())
  businessId    String
  number        String
  date          DateTime
  type          String   // RECEIPT, PAYMENT
  partyId       String
  amount        Decimal
  currency      String   @default("AED")
  exchangeRate  Decimal  @default(1)
  method        String   @default("CASH")
  reference     String?
  bankAccountId String?
  description   String?
  status        String   @default("POSTED")
  customFields  String?
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business      Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  party         Party                @relation(fields: [partyId], references: [id])
  createdBy     User                 @relation("PaymentCreatedBy", fields: [createdById], references: [id])
  allocations   PaymentAllocation[]

  @@unique([businessId, number])
  @@index([partyId])
  @@index([type])
}

model PaymentAllocation {
  id            String   @id @default(cuid())
  paymentId     String
  invoiceId     String?
  billId        String?
  amount        Decimal

  payment       Payment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice       SalesInvoice? @relation(fields: [invoiceId], references: [id])
  bill          PurchaseBill? @relation(fields: [billId], references: [id])
}

// ============================================================
// INVENTORY
// ============================================================

model Item {
  id            String   @id @default(cuid())
  businessId    String
  sku           String
  name          String
  nameAr        String?
  description   String?
  unit          String   @default("PCS")
  category      String?
  salePrice     Decimal  @default(0)
  purchasePrice Decimal  @default(0)
  costMethod    String   @default("WEIGHTED_AVG")
  stockQty      Decimal  @default(0)
  reorderLevel  Decimal  @default(0)
  taxRateId     String?
  isInventory   Boolean  @default(true)
  isActive      Boolean  @default(true)
  customFields  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business      Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  stockMovements StockMovement[]

  @@unique([businessId, sku])
  @@index([businessId, name])
}

model Warehouse {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  code        String
  address     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  business    Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  stockMovements StockMovement[]
}

model StockMovement {
  id            String   @id @default(cuid())
  businessId    String
  itemId        String
  warehouseId   String?
  type          String
  direction     String
  quantity      Decimal
  unitCost      Decimal  @default(0)
  reference     String?
  referenceType String?
  referenceId   String?
  balanceAfter  Decimal
  date          DateTime
  createdAt     DateTime @default(now())

  business      Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  item          Item       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  warehouse     Warehouse? @relation(fields: [warehouseId], references: [id])

  @@index([itemId])
  @@index([businessId, date])
}

// ============================================================
// BANKING
// ============================================================

model BankAccount {
  id            String   @id @default(cuid())
  businessId    String
  name          String
  accountNumber String?
  bankName      String?
  branch        String?
  iban          String?
  openingBalance Decimal @default(0)
  currentBalance Decimal @default(0)
  currency      String   @default("AED")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business      Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transactions  BankTransaction[]
}

model BankTransaction {
  id            String   @id @default(cuid())
  bankAccountId String
  date          DateTime
  description   String?
  reference     String?
  amount        Decimal
  type          String   @default("DEPOSIT")
  isReconciled  Boolean  @default(false)
  reconciledAt  DateTime?
  paymentId     String?
  createdAt     DateTime @default(now())

  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@index([bankAccountId, date])
  @@index([isReconciled])
}

// ============================================================
// CUSTOM FIELDS
// ============================================================

model CustomFieldDefinition {
  id            String   @id @default(cuid())
  businessId    String
  doctype       String
  tab           String   @default("General")
  section       String   @default("Details")
  fieldKey      String
  label         String
  labelAr       String?
  type          String
  options       String?
  defaultValue  String?
  isRequired    Boolean  @default(false)
  isVisible     Boolean  @default(true)
  position      Int      @default(0)
  createdAt     DateTime @default(now())

  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, doctype, fieldKey])
  @@index([businessId, doctype])
}

// ============================================================
// PDF TEMPLATES
// ============================================================

model PdfTemplate {
  id            String   @id @default(cuid())
  businessId    String
  name          String
  doctype       String
  htmlContent   String
  cssContent    String
  isDefault     Boolean  @default(false)
  isSystem      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, name])
  @@index([businessId, doctype])
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id            String   @id @default(cuid())
  businessId    String
  tenantId      String
  userId        String?
  action        String
  entityType    String
  entityId      String
  description   String?
  changes       String?
  ipAddress     String?
  createdAt     DateTime @default(now())

  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User?    @relation(fields: [userId], references: [id])

  @@index([businessId, entityType, entityId])
  @@index([tenantId, createdAt])
}

// ============================================================
// ACTIVITY LOG (document-level chatter, inspired by Odoo/Frappe)
// ============================================================

model ActivityLog {
  id            String   @id @default(cuid())
  businessId    String
  userId        String
  entityType    String   // SALES_INVOICE, PURCHASE_BILL, etc.
  entityId      String
  action        String   // CREATED, UPDATED, POSTED, COMMENTED, EMAILED
  message       String
  metadata      String?  // JSON
  createdAt     DateTime @default(now())

  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id])

  @@index([businessId, entityType, entityId])
  @@index([createdAt])
}

// ============================================================
// APP SETTINGS
// ============================================================

model AppSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
