// AccountERP — Complete Prisma Schema
// UAE-compliant double-entry accounting ERP
// Database: SQLite (dev) / PostgreSQL (prod) — switchable via DATABASE_URL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// CORE / MULTI-TENANT
// ============================================================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  passwordHash  String?
  role          String   @default("ADMIN") // ADMIN, ACCOUNTANT, VIEWER
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  businesses    UserBusiness[]
  journalEntries JournalEntry[]  @relation("JournalEntryCreatedBy")
  invoices       SalesInvoice[]  @relation("InvoiceCreatedBy")
  bills          PurchaseBill[]  @relation("BillCreatedBy")
  payments       Payment[]       @relation("PaymentCreatedBy")
  auditLogs      AuditLog[]
}

model Business {
  id              String   @id @default(cuid())
  name            String
  legalName       String?
  trn             String?  // UAE Tax Registration Number (15 digits)
  email           String?
  phone           String?
  website         String?
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?  // Emirate
  postalCode      String?
  country         String   @default("AE")
  baseCurrency    String   @default("AED")
  fiscalYearStart String   @default("01-01") // MM-DD
  logoUrl         String?
  taxNumber       String?  // alias for TRN
  vatRegistered   Boolean  @default(true)
  vatRate         Decimal  @default(5.00)
  invoicePrefix   String   @default("INV-")
  billPrefix      String   @default("BILL-")
  quotationPrefix String   @default("QT-")
  creditNotePrefix String  @default("CN-")
  receiptPrefix   String   @default("RCT-")
  paymentPrefix   String   @default("PMT-")
  deliveryNotePrefix String @default("DN-")
  nextInvoiceNumber     Int @default(1)
  nextBillNumber        Int @default(1)
  nextQuotationNumber   Int @default(1)
  nextCreditNoteNumber  Int @default(1)
  nextReceiptNumber     Int @default(1)
  nextPaymentNumber     Int @default(1)
  nextDeliveryNoteNumber Int @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users           UserBusiness[]
  accounts        Account[]
  parties         Party[]
  journalEntries  JournalEntry[]
  salesInvoices   SalesInvoice[]
  purchaseBills   PurchaseBill[]
  quotations      Quotation[]
  creditNotes     CreditNote[]
  deliveryNotes   DeliveryNote[]
  payments        Payment[]
  items           Item[]
  bankAccounts    BankAccount[]
  taxRates        TaxRate[]
  currencies      Currency[]
  customFields    CustomFieldDefinition[]
  pdfTemplates    PdfTemplate[]
  auditLogs       AuditLog[]
  warehouses      Warehouse[]
  stockMovements  StockMovement[]
}

model UserBusiness {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  role       String   @default("ADMIN")
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([businessId])
}

// ============================================================
// CHART OF ACCOUNTS
// ============================================================

model Account {
  id          String   @id @default(cuid())
  businessId  String
  code        String   // e.g., "1000", "1000.01"
  name        String
  nameAr      String?
  type        String   // ASSET, LIABILITY, EQUITY, INCOME, EXPENSE
  subtype     String?  // CURRENT_ASSET, FIXED_ASSET, CURRENT_LIABILITY, etc.
  parentId    String?
  description String?
  isControl   Boolean  @default(false) // control account (AR, AP)
  isSystem    Boolean  @default(false) // cannot be deleted
  isActive    Boolean  @default(true)
  openingBalance Decimal @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  parent      Account?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children    Account[] @relation("AccountHierarchy")
  journalLines JournalLine[]

  @@unique([businessId, code])
  @@index([businessId, type])
  @@index([parentId])
}

// ============================================================
// JOURNAL ENTRIES (Double-Entry)
// ============================================================

model JournalEntry {
  id          String   @id @default(cuid())
  businessId  String
  number      String   // sequential journal number
  date        DateTime
  reference   String?  // source document reference
  description String?
  sourceType  String?  // SALES_INVOICE, PURCHASE_BILL, PAYMENT, MANUAL, etc.
  sourceId    String?  // ID of source document
  isPosted    Boolean  @default(false)
  postedAt    DateTime?
  isReversed  Boolean  @default(false)
  reversedById String?
  createdById  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business    Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdBy   User         @relation("JournalEntryCreatedBy", fields: [createdById], references: [id])
  lines       JournalLine[]

  @@unique([businessId, number])
  @@index([businessId, date])
  @@index([sourceType, sourceId])
}

model JournalLine {
  id            String   @id @default(cuid())
  journalEntryId String
  accountId     String
  debit         Decimal  @default(0)
  credit        Decimal  @default(0)
  description   String?
  partyId       String?  // link to party for AR/AP tracking
  party         Party?   @relation(fields: [partyId], references: [id])
  createdAt     DateTime @default(now())

  journalEntry  JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account       Account      @relation(fields: [accountId], references: [id])

  @@index([accountId])
  @@index([journalEntryId])
}

// ============================================================
// PARTIES (Customers & Suppliers)
// ============================================================

model Party {
  id            String   @id @default(cuid())
  businessId    String
  code          String?  // customer/supplier code
  name          String
  nameAr        String?
  type          String   @default("CUSTOMER") // CUSTOMER, SUPPLIER, BOTH
  trn           String?  // UAE TRN (15 digits)
  email         String?
  phone         String?
  website       String?
  contactPerson String?
  billingAddress1   String?
  billingAddress2   String?
  billingCity       String?
  billingState      String?  // Emirate
  billingPostalCode String?
  billingCountry    String   @default("AE")
  shippingAddress1  String?
  shippingAddress2  String?
  shippingCity      String?
  shippingState     String?
  shippingPostalCode String?
  shippingCountry   String   @default("AE")
  paymentTerms  Int      @default(30) // days
  creditLimit   Decimal  @default(0)
  openingBalance Decimal @default(0) // positive = they owe us
  openingBalanceType String @default("DEBIT") // DEBIT (receivable) or CREDIT (payable)
  notes         String?
  isActive      Boolean  @default(true)
  customFields  String?  // JSON
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoices      SalesInvoice[]
  bills         PurchaseBill[]
  payments      Payment[]
  journalLines  JournalLine[]
  quotations    Quotation[]
  creditNotes   CreditNote[]
  deliveryNotes DeliveryNote[]

  @@unique([businessId, code])
  @@index([businessId, type])
}

// ============================================================
// TAX RATES
// ============================================================

model TaxRate {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  nameAr      String?
  rate        Decimal  // 5.00, 0.00
  category    String   // STANDARD_RATED, ZERO_RATED, EXEMPT, OUT_OF_SCOPE
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  business    Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoiceLines SalesInvoiceLine[]
  billLines    PurchaseBillLine[]
  quotationLines QuotationLine[]
  creditNoteLines CreditNoteLine[]

  @@unique([businessId, name])
}

// ============================================================
// CURRENCIES & EXCHANGE RATES
// ============================================================

model Currency {
  id          String   @id @default(cuid())
  businessId  String
  code        String   // AED, USD, EUR
  name        String
  symbol      String
  isBase      Boolean  @default(false)
  exchangeRate Decimal @default(1) // rate to base currency
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, code])
}

// ============================================================
// SALES INVOICES
// ============================================================

model SalesInvoice {
  id            String   @id @default(cuid())
  businessId    String
  number        String
  date          DateTime
  dueDate       DateTime
  partyId       String
  reference     String?  // PO number, etc.
  currency      String   @default("AED")
  exchangeRate  Decimal  @default(1)
  subtotal      Decimal  @default(0)
  totalDiscount Decimal  @default(0)
  totalTax      Decimal  @default(0)
  total         Decimal  @default(0)
  amountPaid    Decimal  @default(0)
  status        String   @default("DRAFT") // DRAFT, POSTED, PAID, PARTIALLY_PAID, OVERDUE, VOID
  notes         String?
  terms         String?
  customFields  String?  // JSON
  einvoiceUuid  String?  // PINT AE UUID
  einvoiceXml   String?  // generated UBL XML
  postedAt      DateTime?
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business      Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  party         Party     @relation(fields: [partyId], references: [id])
  createdBy     User      @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  lines         SalesInvoiceLine[]
  payments      PaymentAllocation[]

  @@unique([businessId, number])
  @@index([businessId, date])
  @@index([partyId])
  @@index([status])
}

model SalesInvoiceLine {
  id            String   @id @default(cuid())
  invoiceId     String
  itemId        String?
  description   String
  quantity      Decimal 
  unitPrice     Decimal 
  discount      Decimal  @default(0) // percentage
  position      Int      @default(0)
  taxRateId     String?
  taxRate       TaxRate?       @relation(fields: [taxRateId], references: [id])
  lineTotal     Decimal  // (qty * price) - discount
  lineTax       Decimal  @default(0)

  invoice       SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ============================================================
// PURCHASE BILLS
// ============================================================

model PurchaseBill {
  id            String   @id @default(cuid())
  businessId    String
  number        String
  date          DateTime
  dueDate       DateTime
  partyId       String
  supplierInvoiceNumber String?
  reference     String?
  currency      String   @default("AED")
  exchangeRate  Decimal  @default(1)
  subtotal      Decimal  @default(0)
  totalDiscount Decimal  @default(0)
  totalTax      Decimal  @default(0)
  total         Decimal  @default(0)
  amountPaid    Decimal  @default(0)
  status        String   @default("DRAFT")
  notes         String?
  customFields  String?
  postedAt      DateTime?
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  party         Party    @relation(fields: [partyId], references: [id])
  createdBy     User     @relation("BillCreatedBy", fields: [createdById], references: [id])
  lines         PurchaseBillLine[]
  payments      PaymentAllocation[]

  @@unique([businessId, number])
  @@index([businessId, date])
  @@index([partyId])
  @@index([status])
}

model PurchaseBillLine {
  id            String   @id @default(cuid())
  billId        String
  itemId        String?
  description   String
  quantity      Decimal 
  unitPrice     Decimal 
  discount      Decimal  @default(0)
  position      Int      @default(0)
  taxRateId     String?
  taxRate       TaxRate?       @relation(fields: [taxRateId], references: [id])
  lineTotal     Decimal 
  lineTax       Decimal  @default(0)

  bill          PurchaseBill @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
}

// ============================================================
// QUOTATIONS
// ============================================================

model Quotation {
  id            String   @id @default(cuid())
  businessId    String
  number        String
  date          DateTime
  validUntil    DateTime?
  partyId       String
  reference     String?
  currency      String   @default("AED")
  subtotal      Decimal  @default(0)
  totalDiscount Decimal  @default(0)
  totalTax      Decimal  @default(0)
  total         Decimal  @default(0)
  status        String   @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, EXPIRED, CONVERTED
  notes         String?
  terms         String?
  customFields  String?
  convertedInvoiceId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  party         Party    @relation(fields: [partyId], references: [id])
  lines         QuotationLine[]

  @@unique([businessId, number])
  @@index([partyId])
}

model QuotationLine {
  id            String   @id @default(cuid())
  quotationId   String
  itemId        String?
  description   String
  quantity      Decimal 
  unitPrice     Decimal 
  discount      Decimal  @default(0)
  position      Int      @default(0)
  taxRateId     String?
  taxRate       TaxRate?       @relation(fields: [taxRateId], references: [id])
  lineTotal     Decimal 
  lineTax       Decimal  @default(0)

  quotation     Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

// ============================================================
// CREDIT NOTES
// ============================================================

model CreditNote {
  id            String   @id @default(cuid())
  businessId    String
  number        String
  date          DateTime
  partyId       String
  originalInvoiceId String?
  reference     String?
  currency      String   @default("AED")
  subtotal      Decimal  @default(0)
  totalTax      Decimal  @default(0)
  total         Decimal  @default(0)
  status        String   @default("DRAFT")
  reason        String?
  notes         String?
  customFields  String?
  postedAt      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  party         Party    @relation(fields: [partyId], references: [id])
  lines         CreditNoteLine[]

  @@unique([businessId, number])
}

model CreditNoteLine {
  id            String   @id @default(cuid())
  creditNoteId  String
  description   String
  quantity      Decimal 
  unitPrice     Decimal 
  position      Int      @default(0)
  taxRateId     String?
  taxRate       TaxRate?       @relation(fields: [taxRateId], references: [id])
  lineTotal     Decimal 
  lineTax       Decimal  @default(0)

  creditNote    CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
}

// ============================================================
// DELIVERY NOTES
// ============================================================

model DeliveryNote {
  id            String   @id @default(cuid())
  businessId    String
  number        String
  date          DateTime
  partyId       String
  invoiceId     String?
  reference     String?
  status        String   @default("DRAFT") // DRAFT, DELIVERED, CANCELLED
  notes         String?
  customFields  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business      Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  party         Party             @relation(fields: [partyId], references: [id])
  lines         DeliveryNoteLine[]

  @@unique([businessId, number])
}

model DeliveryNoteLine {
  id            String   @id @default(cuid())
  deliveryNoteId String
  itemId        String?
  description   String
  quantity      Decimal 
  position      Int      @default(0)

  deliveryNote  DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
}

// ============================================================
// PAYMENTS (Receipts & Payments)
// ============================================================

model Payment {
  id            String   @id @default(cuid())
  businessId    String
  number        String
  date          DateTime
  type          String   // RECEIPT (from customer), PAYMENT (to supplier)
  partyId       String
  amount        Decimal 
  currency      String   @default("AED")
  exchangeRate  Decimal  @default(1)
  method        String   @default("CASH") // CASH, CHEQUE, BANK_TRANSFER, CARD, ONLINE
  reference     String?  // cheque no, transaction id
  bankAccountId String?
  description   String?
  status        String   @default("POSTED")
  customFields  String?
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business      Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  party         Party                @relation(fields: [partyId], references: [id])
  createdBy     User                 @relation("PaymentCreatedBy", fields: [createdById], references: [id])
  allocations   PaymentAllocation[]

  @@unique([businessId, number])
  @@index([partyId])
  @@index([type])
}

model PaymentAllocation {
  id            String   @id @default(cuid())
  paymentId     String
  invoiceId     String?
  billId        String?
  amount        Decimal 

  payment       Payment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice       SalesInvoice? @relation(fields: [invoiceId], references: [id])
  bill          PurchaseBill? @relation(fields: [billId], references: [id])
}

// ============================================================
// INVENTORY
// ============================================================

model Item {
  id            String   @id @default(cuid())
  businessId    String
  sku           String
  name          String
  nameAr        String?
  description   String?
  unit          String   @default("PCS") // PCS, KG, LTR, HR, etc.
  category      String?
  salePrice     Decimal  @default(0)
  purchasePrice Decimal  @default(0)
  costMethod    String   @default("WEIGHTED_AVG") // FIFO, WEIGHTED_AVG
  stockQty      Decimal  @default(0)
  reorderLevel  Decimal  @default(0)
  taxRateId     String?
  isInventory   Boolean  @default(true)
  isActive      Boolean  @default(true)
  customFields  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business      Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  stockMovements StockMovement[]

  @@unique([businessId, sku])
  @@index([businessId, name])
}

model Warehouse {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  code        String
  address     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  business    Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  stockMovements StockMovement[]
}

model StockMovement {
  id            String   @id @default(cuid())
  businessId    String
  itemId        String
  warehouseId   String?
  type          String   // PURCHASE, SALE, ADJUSTMENT, TRANSFER, RETURN
  direction     String   // IN, OUT
  quantity      Decimal 
  unitCost      Decimal  @default(0)
  reference     String?  // source doc number
  referenceType String?  // SALES_INVOICE, PURCHASE_BILL, etc.
  referenceId   String?
  balanceAfter  Decimal 
  date          DateTime
  createdAt     DateTime @default(now())

  business      Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  item          Item       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  warehouse     Warehouse? @relation(fields: [warehouseId], references: [id])

  @@index([itemId])
  @@index([businessId, date])
}

// ============================================================
// BANKING
// ============================================================

model BankAccount {
  id            String   @id @default(cuid())
  businessId    String
  name          String
  accountNumber String?
  bankName      String?
  branch        String?
  iban          String?
  accountId     String?  // linked GL account
  openingBalance Decimal @default(0)
  currentBalance Decimal @default(0)
  currency      String   @default("AED")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business      Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transactions  BankTransaction[]
}

model BankTransaction {
  id            String   @id @default(cuid())
  bankAccountId String
  date          DateTime
  description   String?
  reference     String?
  amount        Decimal  // positive = deposit, negative = withdrawal
  type          String   @default("DEPOSIT") // DEPOSIT, WITHDRAWAL, FEE, INTEREST
  isReconciled  Boolean  @default(false)
  reconciledAt  DateTime?
  paymentId     String?
  createdAt     DateTime @default(now())

  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@index([bankAccountId, date])
  @@index([isReconciled])
}

// ============================================================
// CUSTOM FIELDS
// ============================================================

model CustomFieldDefinition {
  id            String   @id @default(cuid())
  businessId    String
  doctype       String   // SALES_INVOICE, PURCHASE_BILL, PARTY, ITEM, etc.
  tab           String   @default("General") // tab name
  section       String   @default("Details") // section name
  fieldKey      String   // internal key
  label         String
  labelAr       String?
  type          String   // TEXT, NUMBER, DECIMAL, DATE, SELECT, CHECKBOX, TEXTAREA, LINK
  options       String?  // JSON: for SELECT choices, LINK target, etc.
  defaultValue  String?
  isRequired    Boolean  @default(false)
  isVisible     Boolean  @default(true)
  position      Int      @default(0)
  createdAt     DateTime @default(now())

  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, doctype, fieldKey])
  @@index([businessId, doctype])
}

// ============================================================
// PDF TEMPLATES
// ============================================================

model PdfTemplate {
  id            String   @id @default(cuid())
  businessId    String
  name          String
  doctype       String   // SALES_INVOICE, PURCHASE_BILL, QUOTATION, CREDIT_NOTE, DELIVERY_NOTE, STATEMENT
  htmlContent   String   // HTML template with placeholders
  cssContent    String   // CSS styles
  isDefault     Boolean  @default(false)
  isSystem      Boolean  @default(false) // built-in, cannot be deleted
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, name])
  @@index([businessId, doctype])
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id            String   @id @default(cuid())
  businessId    String
  userId        String?
  action        String   // CREATE, UPDATE, DELETE, POST, VOID
  entityType    String   // SALES_INVOICE, JOURNAL_ENTRY, etc.
  entityId      String
  description   String?
  changes       String?  // JSON of before/after
  ipAddress     String?
  createdAt     DateTime @default(now())

  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user          User?    @relation(fields: [userId], references: [id])

  @@index([businessId, entityType, entityId])
  @@index([businessId, createdAt])
}

// ============================================================
// APP SETTINGS (single-tenant config)
// ============================================================

model AppSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
